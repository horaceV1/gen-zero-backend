# Ignore directories generated by Composer
/vendor/
/web/core/
/web/modules/contrib/
/web/themes/contrib/
/web/profiles/contrib/
/web/libraries/
/libraries/

# Ignore sensitive information
/web/sites/*/settings.php
/web/sites/*/settings.local.php
/web/sites/*/services.yml

# Ignore Drupal's file directories
/web/sites/*/files/
/web/sites/*/private/
/private/

# Ignore SimpleTest multi-site environment
/web/sites/simpletest/

# Ignore database dumps
*.sql
*.sql.gz

# Ignore development files
*.orig
*.rej
*.swp
*~
.DS_Store
*.sublime-project
*.sublime-workspace

# Ignore IDE files
/.idea/
/.vscode/
/.editorconfig
/.gitattributes

# Ignore environment-specific files
/.env
/.env.local
/.ddev/

# Ignore Drush contrib
/drush/contrib/
/drush/sites/

# Ignore PHPUnit test results
/web/sites/default/phpunit.xml

# Ignore Drupal console
/.console/
/.drupal/

# Ignore temporary files
/tmp/
*.tmp

# Ignore composer binaries (regenerated by composer install)
/bin/

frontend/
